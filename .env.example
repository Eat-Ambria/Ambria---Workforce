# Copy this file to ".env" and fill in your Supabase anon key.
# Where to find: Supabase Dashboard -> Project Settings -> API
#   - "Project URL"      -> VITE_SUPABASE_URL
#   - "anon public" key  -> VITE_SUPABASE_ANON_KEY   (safe for frontend/PWA)

VITE_SUPABASE_URL=https://kwqbgymqbcfvtvelunxo.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Web Push (Phase 2). Generate a key pair once with:  npx web-push generate-vapid-keys
# Put the PUBLIC key here (safe for the frontend). The PRIVATE key goes in the
# Supabase Edge Function secrets, NOT here. Leave blank to disable push in the UI.
VITE_VAPID_PUBLIC_KEY=
